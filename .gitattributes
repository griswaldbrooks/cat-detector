# SCM syntax highlighting & preventing 3-way merges
pixi.lock merge=binary linguist-language=YAML linguist-generated=true

# Git LFS — track image files
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text

# Exclude website static assets from LFS (GitHub Pages serves raw files)
website/static/img/**/*.jpg !filter !diff !merge text=auto
website/static/img/**/*.jpeg !filter !diff !merge text=auto
website/static/img/**/*.png !filter !diff !merge text=auto
website/static/img/*.jpg !filter !diff !merge text=auto
website/static/img/*.jpeg !filter !diff !merge text=auto
website/static/img/*.png !filter !diff !merge text=auto
